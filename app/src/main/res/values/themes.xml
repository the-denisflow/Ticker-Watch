<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Kotlin_App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Force dark status bar icons so the time is visible on white background -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Kotlin_App" parent="Base.Theme.Kotlin_App" />

    <style name="Theme.Kotlin_App.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">#3DDC84</item>
        <item name="postSplashScreenTheme">@style/Theme.Kotlin_App</item>
    </style>
</resources>